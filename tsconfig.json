{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "lib": ["es2020"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "rootDir": "./src",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}